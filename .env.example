# Copy to .env and fill in. NEVER commit the real .env.

# SQLite database location.
#   Local dev:  file:./dev.db  (relative to the prisma/ directory)
#   Production: file:/data/app.db  (persistent Coolify volume)
DATABASE_URL="file:./dev.db"

# Auth.js session encryption secret. Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-long-random-string"

# Trust the host header behind Coolify's reverse proxy.
AUTH_TRUST_HOST="true"

# Public origin of the app, scheme + host + port, no trailing slash. Auth.js builds its
# sign-in/callback URLs from this. Leave unset for local dev. In production set it to the
# real URL including the port — the proxy's forwarded-host header drops the non-standard
# port, so host auto-detection alone resolves to the wrong origin.
# AUTH_URL="https://diploma.panel.enset-skikda.dz:8000"

# Initial admin account created by the seed script (npm run seed).
ADMIN_EMAIL="admin@univ-constantine2.dz"
ADMIN_PASSWORD="change-me-strong-password"
ADMIN_NAME="Administrator"

# --- Production (Coolify) only ---
# Where uploaded template scans are stored (mount a persistent volume at /data).
# UPLOADS_DIR="/data/uploads"
# Internal URL the headless-Chromium PDF renderer uses to reach this app.
# PDF_RENDER_BASE_URL="http://127.0.0.1:3000"
# Optional: dedicated secret for internal render auth (defaults to AUTH_SECRET).
# RENDER_TOKEN="another-long-random-string"
